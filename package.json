{
  "name": "odins-blog",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm generate:images && astro build && pnpm optimize:images",
    "generate:images": "node scripts/generate-responsive-images.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "oxlint . --fix",
    "lint:check": "oxlint .",
    "format": "oxfmt --write .",
    "fmt": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "ci": "pnpm check && pnpm lint:check && pnpm format:check && pnpm build"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource-variable/lora": "5.2.8",
    "@fontsource-variable/newsreader": "5.2.10",
    "@tailwindcss/vite": "^4.2.1",
    "lucide-react": "^0.575.0",
    "posthog-js": "^1.399.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "6.0.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "astro": "7.0.3",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "sharp": "0.34.5",
    "typescript": "^5.8.3",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@10.33.0"
}
