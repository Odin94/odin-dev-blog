---
import "../styles.css";
import PostHog from "@/components/PostHog.astro";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  lang?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
}

const {
  title,
  description,
  noindex = false,
  lang = "en",
  image = "/profile_25.webp",
  type = "website",
  publishedTime,
  tags = [],
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://odin-matthias.de");
const imageUrl = new URL(image, Astro.site ?? "https://odin-matthias.de");
const locale = lang === "de" ? "de_DE" : "en_US";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://odin-matthias.de/#website",
      url: "https://odin-matthias.de/",
      name: "Odin Matthias",
      description:
        "Software developer building approachable tools for tabletop roleplaying games.",
      inLanguage: ["en", "de"],
    },
    {
      "@type": "Person",
      "@id": "https://odin-matthias.de/#person",
      name: "Odin Matthias",
      url: "https://odin-matthias.de/",
      image: "https://odin-matthias.de/profile_25.webp",
      jobTitle: "Software Developer",
      sameAs: [
        "https://github.com/Odin94",
        "https://bsky.app/profile/odinmatthias.bsky.social",
        "https://ko-fi.com/odin_dev",
      ],
    },
    ...(type === "article" && publishedTime
      ? [
          {
            "@type": "BlogPosting",
            "@id": `${canonicalUrl}#article`,
            headline: title.replace(/ — Odin Matthias$/, ""),
            description,
            image: imageUrl.toString(),
            datePublished: publishedTime,
            mainEntityOfPage: canonicalUrl.toString(),
            author: { "@id": "https://odin-matthias.de/#person" },
            publisher: { "@id": "https://odin-matthias.de/#person" },
            keywords: tags.join(", "),
            inLanguage: lang,
          },
        ]
      : []),
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Odin Matthias" />
    <meta
      name="robots"
      content={noindex
        ? "noindex, follow"
        : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    <meta name="theme-color" content="#f7f1df" />
    <meta name="color-scheme" content="light" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Odin Matthias" />
    <meta property="og:locale" content={locale} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={`Preview image for ${title}`} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <link rel="canonical" href={canonicalUrl} />
    <meta name="twitter:card" content={type === "article" ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={`Preview image for ${title}`} />
    <link rel="icon" href="/leaf-svgrepo-com.svg" type="image/svg+xml" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {lang === "de" ? "Zum Hauptinhalt springen" : "Skip to main content"}
    </a>
    <PostHog />
    <slot />
  </body>
</html>
