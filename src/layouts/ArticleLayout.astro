---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { WavyBackdrop } from "@/components/WavyBackdrop";

const { title, description, date, category, socialImage, tags = [] } = Astro.props.frontmatter;
const displayDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(new Date(date));
---

<BaseLayout
  title={`${title} — Odin Matthias`}
  description={description}
  image={socialImage}
  type="article"
  publishedTime={date}
  tags={tags}
>
  <div class="relative min-h-screen">
    <WavyBackdrop />

    <main id="main-content" class="mx-auto w-full max-w-3xl px-5 pt-10 pb-16 sm:px-8 sm:pt-16">
      <header class="mb-10 flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.22em] text-muted-foreground">
        <a href="/blog/" class="transition-colors hover:text-stamp">← The notebook</a>
        <a href="/" class="hidden transition-colors hover:text-stamp sm:inline">Odin Matthias</a>
      </header>

      <article>
        <header class="paper-grain relative rounded-lg border border-ink/10 bg-card/90 p-6 shadow-[0_1px_0_rgba(0,0,0,0.03),0_20px_40px_-20px_rgba(60,40,20,0.25)] backdrop-blur-sm sm:p-9">
          <span class="tape-strip -top-3 left-8 -rotate-6" aria-hidden="true" />
          <span class="tape-strip -top-3 right-10 rotate-3" aria-hidden="true" />
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-[10px] uppercase tracking-[0.2em] text-stamp">
            <time datetime={date}>{displayDate}</time>
            <span aria-hidden="true">•</span>
            <span>{category}</span>
          </div>
          <h1 class="mt-3 font-display text-4xl leading-[1.02] tracking-tight text-balance sm:text-6xl">
            {title}
          </h1>
          <p class="mt-5 max-w-[58ch] text-lg leading-relaxed text-pretty text-ink/80">
            {description}
          </p>
        </header>

        <div class="paper-grain article-body mt-12 rounded-md border border-ink/10 bg-card/85 px-6 py-8 shadow-[0_18px_30px_-28px_rgba(60,40,20,0.45)] sm:px-10 sm:py-12">
          <slot />
        </div>
      </article>

      <footer class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-ink/10 pt-8 text-center font-mono text-[11px] uppercase tracking-widest text-muted-foreground sm:flex-row sm:text-left">
        <div>© {new Date().getFullYear()} Odin Matthias</div>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2">
          <a href="/impressum/" class="hover:text-stamp">Impressum</a>
          <a href="/datenschutz/" class="hover:text-stamp">Datenschutz</a>
          <button type="button" data-privacy-settings class="hover:text-stamp">
            Datenschutzeinstellungen
          </button>
        </div>
      </footer>
    </main>
  </div>
</BaseLayout>

<style is:global>
  .article-body {
    color: color-mix(in oklch, var(--color-ink) 82%, transparent);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .article-body > * + * {
    margin-top: 1.5rem;
  }

  .article-body h2,
  .article-body h3 {
    color: var(--color-ink);
    line-height: 1.15;
  }

  .article-body h2 {
    margin-top: 3.5rem;
    font-size: 2rem;
  }

  .article-body h3 {
    margin-top: 2.5rem;
    font-size: 1.5rem;
  }

  .article-body a {
    color: var(--color-stamp);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklch, var(--color-stamp) 42%, transparent);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.2em;
  }

  .article-body a:hover {
    color: var(--color-ink);
  }

  .article-body ul {
    padding-left: 1.4rem;
    list-style: disc;
  }

  .article-body li + li {
    margin-top: 0.45rem;
  }

  .article-body strong {
    color: var(--color-ink);
  }

  .article-body img {
    width: 100%;
    margin: 2rem 0;
    border: 1px solid color-mix(in oklch, var(--color-ink) 14%, transparent);
    border-radius: 0.25rem;
    box-shadow: 0 14px 26px -22px rgb(60 40 20 / 0.65);
  }

  .article-body pre {
    overflow-x: auto;
    padding: 1.25rem;
    border: 1px solid color-mix(in oklch, var(--color-ink) 13%, transparent);
    border-radius: 0.35rem;
    background: color-mix(in oklch, var(--color-parchment-2) 72%, var(--color-ink));
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .article-body blockquote {
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-stamp-soft);
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
    font-style: italic;
  }
</style>
