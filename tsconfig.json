{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "astro.config.ts", "scripts/**/*.ts", "src/**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
